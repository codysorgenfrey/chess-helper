# ── LLM / AI Coach Configuration ──────────────────────────────────────────────
#
# These settings are used SERVER-SIDE by the Azure Function at /api/llm.
# They are NOT exposed to the frontend.
#
# For local development: copy to api/local.settings.json under "Values".
# For production: set these in Azure Static Web Apps → Configuration → App Settings.
#
# Provider: "azure" or "openai"
LLM_PROVIDER=azure
#
# ── Azure AI Foundry / Azure OpenAI ──
LLM_API_KEY=your-azure-api-key-here
LLM_BASE_URL=https://your-resource.openai.azure.com
LLM_MODEL=gpt-4o-mini
LLM_AZURE_API_VERSION=2024-12-01-preview
#
# ── OpenAI (use these instead if using OpenAI directly) ──
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
